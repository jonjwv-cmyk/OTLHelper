<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow halo -->
    <item>
        <shape>
            <solid android:color="#1AEF4444" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Inner glow ring -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape>
            <solid android:color="#0DEF4444" />
            <corners android:radius="17dp" />
        </shape>
    </item>
    <!-- Card body -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape>
            <solid android:color="#1A0E0E" />
            <corners android:radius="15dp" />
            <stroke
                android:width="1.5dp"
                android:color="#EF4444" />
        </shape>
    </item>
</layer-list>
