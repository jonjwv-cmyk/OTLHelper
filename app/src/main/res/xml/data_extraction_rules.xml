<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data-extraction rules (`android:dataExtractionRules`).

  Both cloud backup and device-to-device migration are disabled for this
  app. Rationale:
    - We hold session tokens in EncryptedSharedPreferences and an encrypted
      SQLCipher database. Cloud/backup would exfiltrate user-scoped secrets
      in a form we can't reproduce remotely.
    - All persistent data is cheap to refetch from the server after a
      reinstall — the user logs in and their state restores from D1/R2.

  Explicit `<exclude domain="*"/>` on both cloud-backup and device-transfer
  makes the policy intent unambiguous even if Android ever changes its
  default.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
