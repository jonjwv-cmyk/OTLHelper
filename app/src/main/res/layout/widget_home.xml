<?xml version="1.0" encoding="utf-8"?>
<!--
    OTL Helper home-screen widget — defensive implementation.

    Only primitives that inflate cleanly in RemoteViews across all OEM
    launchers (Pixel, Samsung One UI, Xiaomi MIUI, OPPO, Nothing):
      · LinearLayout as root
      · ImageView with @mipmap/ic_launcher (composed adaptive icon)
      · TextViews with plain colors and solid paddings
      · No shape drawables as backgrounds, no FrameLayout, no tooling namespace
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1C"
    android:padding="14dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/widget_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="@string/app_name" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTL Helper"
                android:textColor="#F0F0F2"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Открыть"
                android:textColor="#9A9AA0"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_counter_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="28dp"
            android:paddingLeft="9dp"
            android:paddingRight="9dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="#222233"
            android:gravity="center"
            android:textColor="#7C8FE4"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:text="" />
    </LinearLayout>

    <!-- Pinned label -->
    <TextView
        android:id="@+id/widget_pinned_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="ЗАКРЕПЛЕНО"
        android:textColor="#7C8FE4"
        android:textSize="10sp"
        android:textStyle="bold"
        android:maxLines="1" />

    <!-- Pinned slots -->
    <TextView
        android:id="@+id/widget_pinned_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text=""
        android:textColor="#F0F0F2"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_pinned_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="#F0F0F2"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_pinned_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="#F0F0F2"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Update chip -->
    <TextView
        android:id="@+id/widget_update_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text=""
        android:textColor="#22C55E"
        android:textSize="11sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
